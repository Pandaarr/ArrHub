# ArrHub - Stack Docker média complète pour Synology, Portainer et VPN
# Testée sur Synology DS918+ (DSM 7.1.1-42962 Update 6)
# Compatible avec la plupart des serveurs Docker moyennant quelques adaptations
# Guide d'installation : https://github.com/Pandaarr/docker-compose-advanced-media#guide

# IMPORTANT :
# Monter /volume1/media dans TOUS les containers utilisant les médias afin de permettre à Radarr et Sonarr d'utiliser les hardlinks.
# Ne pas monter séparément Films, Series et Torrents.

version: "3"
services:
  radarr:
	# automatisation et gestion de telechargement de films : https://radarr.video/
	# ne passe pas par le tunnel VPN, non accessible en dehors du réseau local, configurer un reverse proxy pour y accéder depuis l'extérieur (port 443 vers 7878 avec nom de source personnalisée)
    container_name: radarr
    image: linuxserver/radarr:latest
    restart: unless-stopped
    ports:
     - 7878:7878
    volumes:
      - /volume1/docker/radarr:/config
      - /volume1/media:/media
    environment:
     - PUID=XXXX
     - PGID=XXXX
     - TZ=Europe/Paris

  sonarr:
	# automatisation et gestion de telechargement de series : https://sonarr.tv/
	# ne passe pas par le tunnel VPN, non accessible en dehors du réseau local, configurer un reverse proxy pour y accéder depuis l'extérieur (port 443 vers 8989 avec nom de source personnalisée)
    container_name: sonarr
    image: linuxserver/sonarr:latest
    restart: unless-stopped
    ports:
     - 8989:8989
    volumes:
      - /volume1/docker/sonarr:/config
      - /volume1/media:/media
    environment:
     - PUID=XXXX
     - PGID=XXXX
     - TZ=Europe/Paris

  bazarr:
	# automatisation et gestion de telechargement de sous-titres pour films et series : https://www.bazarr.media/
	# ne passe pas par le tunnel VPN, non accessible en dehors du réseau local, configurer un reverse proxy pour y accéder depuis l'extérieur (port 443 vers 6767 avec nom de source personnalisée)
    container_name: bazarr
    image: ghcr.io/linuxserver/bazarr:latest
    environment:
      - PUID=XXXX
      - PGID=XXXX
      - TZ=Europe/Paris
    volumes:
      - /volume1/docker/bazarr:/config
      - /volume1/media:/media
    ports:
      - 6767:6767
    restart: unless-stopped

  seerr:
	# outil de gestion des requetes (les votres et ceux des utilisateurs de votre Plex) et de découverte de medias concu pour fonctionner avec Plex, Radarr et Sonarr : https://overseerr.dev/
	# ne passe pas par le tunnel VPN, non accessible en dehors du réseau local, configurer un reverse proxy pour y accéder depuis l'extérieur (port 443 vers 5055 avec nom de source personnalisée)
    container_name: seerr
    image: ghcr.io/seerr-team/seerr:latest
    environment:
      - PUID=XXXX
      - PGID=XXXX
      - TZ=Europe/Paris
    volumes:
      - /volume1/docker/seerr:/config
    ports:
      - 5055:5055
    restart: unless-stopped

  gluetun:
	# client VPN pour plusieurs fournisseurs VPN, ecrit en Go et utilisant OpenVPN ou Wireguard, DNS sur TLS, avec quelques serveurs proxy integres : https://github.com/qdm12/gluetun#features
	# exemple pour Proton VPN
    image: qmcgaw/gluetun:latest
    container_name: gluetun
    hostname: gluetun
    labels:
      com.centurylinklabs.watchtower.enable: "false" # la MAJ de Watchtower fait crasher le network des autres containers lies a gluetun, il vaut mieux forcer la MAJ en manuel de temps en temps, cf. watchtower tout en bas
    # line above must be uncommented to allow external containers to connect. See https://github.com/qdm12/gluetun/wiki/Connect-a-container-to-gluetun#external-container-to-gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    ports:
      - 8888:8888/tcp # HTTP proxy
      - 8388:8388/tcp # Shadowsocks
      - 8388:8388/udp # Shadowsocks
      - 8080:8080/tcp # qBittorrent Web UI
      - 8191:8191/tcp # Flaresolverr Web UI
      - 9117:9117/tcp # Jackett Web UI
      - 9696:9696/tcp # Prowlarr
      - 2468:2468/tcp # Cross-seed UI
    volumes:
      - /volume1/docker/gluetun:/gluetun
    environment:
      # See https://github.com/qdm12/gluetun/wiki
      - VPN_SERVICE_PROVIDER=protonvpn
      - VPN_TYPE=wireguard
      # Wireguard :
      - BLOCK_MALICIOUS=off
      - WIREGUARD_PRIVATE_KEY=XXXX
      - SERVER_COUNTRIES=France
      #- SERVER_COUNTRIES=Netherlands
      - PORT_FORWARD_ONLY=on
      - VPN_PORT_FORWARDING=on
      - VPN_PORT_FORWARDING_UP_COMMAND=/bin/sh -c 'wget -O- --retry-connrefused --post-data "json={\"listen_port\":{{PORT}}}" http://127.0.0.1:8080/api/v2/app/setPreferences 2>&1' # pour MAJ le port forward automatiquement sur qbittorrent
      # Timezone for accurate log times
      - TZ=Europe/Paris
      - FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/24
      - PUID=XXXX
      - PGID=XXXX
    restart: always
      
  flaresolverr:
	# serveur proxy pour contourner la protection Cloudflare et DDoS-GUARD, genre celle qu'il y a parfois sur YGG, a renseigner dans Jackett : https://github.com/FlareSolverr/FlareSolverr
    #DockerHub mirror flaresolverr/flaresolverr:latest
    #image: ghcr.io/flaresolverr/flaresolverr:latest
    #image: ghcr.io/flaresolverr/flaresolverr:pr-1282
    image: 21hsmw/flaresolverr:nodriver
    container_name: flaresolverr
    depends_on:
        - gluetun
    environment:
      - LOG_LEVEL=${LOG_LEVEL:-info}
      - LOG_HTML=${LOG_HTML:-false}
      - CAPTCHA_SOLVER=${CAPTCHA_SOLVER:-none}
      - TZ=Europe/Paris
      - DRIVER=nodriver
    restart: always
    # la ligne ci-dessous signifie que ce container utilise la connection du client VPN Gluetun
    network_mode: "service:gluetun"
    
  jackett:
	# passerelle entre vos trackers torrent et Radarr, Sonarr... : https://github.com/Jackett/Jackett
    image: lscr.io/linuxserver/jackett:latest
    container_name: jackett
    depends_on:
        - gluetun
    environment:
      - PUID=XXXX
      - PGID=XXXX
      - TZ=Europe/Paris
      - AUTO_UPDATE=true # optional
    volumes:
      - /volume1/docker/jackett/config:/config
      - /volume1/docker/jackett/downloads:/downloads
    labels:
      com.centurylinklabs.watchtower.enable: "false"
    restart: always
    # la ligne ci-dessous signifie que ce container utilise la connection du client VPN Gluetun
    network_mode: "service:gluetun"

  prowlarr:
	# alternative à jackett : https://github.com/prowlarr/prowlarr
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    depends_on:
        - gluetun
    environment:
      - PUID=XXXX
      - PGID=XXXX
      - TZ=Europe/Paris
    volumes:
      - /volume1/docker/prowlarr/data:/config
    restart: always
    # la ligne ci-dessous signifie que ce container utilise la connection du client VPN Gluetun
    network_mode: "service:gluetun"

  cross-seed:
	# outil de partage de torrents/médias automatique sur plusieurs trackers : https://github.com/cross-seed/cross-seed
    image: ghcr.io/cross-seed/cross-seed:latest
    container_name: cross-seed
    depends_on:
        - gluetun
        - qbittorrent
    user: XXXX:XXXX # this must match your torrent client (cross-seed does not support using PGID and PUID)
    environment: 
      - TZ=Europe/Paris
    labels:
      com.centurylinklabs.watchtower.enable: "false"
    volumes:
      - /volume1/docker/cross-seed:/config
      - /volume1/media:/media
    command: daemon --verbose
    restart: always
    network_mode: "service:gluetun"

  cleanuparr:
    # nettoyage automatique des torrents selon ratio, temps de seed ou état dans Radarr/Sonarr : https://github.com/Cleanuparr/Cleanuparr
    # ne passe pas par le tunnel VPN, aucune exposition Internet nécessaire
    container_name: cleanuparr
    image: ghcr.io/cleanuparr/cleanuparr:latest
    depends_on:
      - qbittorrent
      - radarr
      - sonarr
    environment:
      - TZ=Europe/Paris
      - PUID=XXXX
      - PGID=XXXX
    volumes:
      - /volume1/docker/cleanuparr:/config
    restart: unless-stopped

  qbittorrent:
	# client torrent de qualité : https://www.qbittorrent.org/
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    depends_on:
        - gluetun
    environment:
      - PUID=XXXX
      - PGID=XXXX
      - TZ=Europe/Paris
      - WEBUI_PORT=8080
    volumes:
      - /volume1/docker/qbittorrent/config:/config
      - /volume1/media:/media
    restart: always
    # la ligne ci-dessous signifie que ce container utilise la connection du client VPN Gluetun
    network_mode: "service:gluetun"

  watchtower:
	# MAJ automatique de toutes les images de vos containers ne contenant pas le label 'com.centurylinklabs.watchtower.enable: "false"'
   	# ne passe pas par le tunnel VPN
    container_name: watchtower
    image: containrrr/watchtower:latest
    restart: always
    # pour lancer manuellement une MAJ, décommenter la ligne en-dessous et updater la stack ; il faudra re-updater la stack complete si Gluetun est MAJ afin que les containers passant par son network soient a nouveau fonctionnel
    #command: --run-once
    environment:
      - TZ=Europe/Paris
      - WATCHTOWER_SCHEDULE= 0 0 6 * * *
      - WATCHTOWER_LABEL_ENABLE=false
      - WATCHTOWER_CLEANUP=true
      - WATCHTOWER_REMOVE_VOLUMES=true
      - WATCHTOWER_NOTIFICATIONS_LEVEL=debug
      - WATCHTOWER_INCLUDE_STOPPED=true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
